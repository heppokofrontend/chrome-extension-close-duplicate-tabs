{
  "name": "chrome-extension-close-duplicate-tabs",
  "description": "This is a Google Chrome extension that closes duplicate tabs in the current window.",
  "version": "1.2.4",
  "author": "heppokofrontend",
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "bugs": {
    "url": "https://github.com/heppokofrontend/chrome-extension-close-duplicate-tabs/issues"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/chrome": "0.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "gh-pages": "6.3.0",
    "globals": "17.7.0",
    "http-server": "14.1.1",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "homepage": "https://github.com/heppokofrontend/chrome-extension-close-duplicate-tabs#readme",
  "keywords": [],
  "license": "MIT",
  "packageManager": "npm@11.17.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heppokofrontend/chrome-extension-close-duplicate-tabs.git"
  },
  "scripts": {
    "build": "npm run typecheck && npm run build:content && npm run build:popup && npm run build:worker && npm run build:duplicates-list && npm run build:common",
    "build:content": "esbuild src/content-scripts.ts --bundle --minify --format=iife --target=chrome120 --outfile=package/content-scripts.js",
    "build:popup": "esbuild src/popup.ts --bundle --minify --format=iife --target=chrome120 --outfile=package/popup.js",
    "build:worker": "esbuild src/worker.ts --bundle --minify --format=iife --target=chrome120 --outfile=package/worker.js",
    "build:duplicates-list": "esbuild src/duplicates-list.ts --bundle --minify --format=iife --target=chrome120 --outfile=package/duplicates-list.js",
    "build:common": "esbuild src/common.ts --bundle --minify --format=iife --target=chrome120 --outfile=package/common.js",
    "deploy": "gh-pages -d package -b package",
    "dev:content": "esbuild src/content-scripts.ts --bundle --format=iife --target=chrome120 --sourcemap=inline --outfile=package/content-scripts.js --watch",
    "dev:popup": "esbuild src/popup.ts --bundle --format=iife --target=chrome120 --sourcemap=inline --outfile=package/popup.js --watch",
    "dev:worker": "esbuild src/worker.ts --bundle --format=iife --target=chrome120 --sourcemap=inline --outfile=package/worker.js --watch",
    "dev:duplicates-list": "esbuild src/duplicates-list.ts --bundle --format=iife --target=chrome120 --sourcemap=inline --outfile=package/duplicates-list.js --watch",
    "dev:common": "esbuild src/common.ts --bundle --format=iife --target=chrome120 --sourcemap=inline --outfile=package/common.js --watch",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "predeploy": "npm run build",
    "serve": "http-server ./ -o index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
