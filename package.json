{
  "name": "chrome-extension-close-duplicate-tabs",
  "description": "This is a Google Chrome extension that closes duplicate tabs in the current window.",
  "version": "1.5.1",
  "author": "heppokofrontend",
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "bugs": {
    "url": "https://github.com/heppokofrontend/chrome-extension-close-duplicate-tabs/issues"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/chrome": "0.2.0",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-node": "0.4.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "gh-pages": "6.3.0",
    "globals": "17.7.0",
    "http-server": "14.1.1",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "homepage": "https://github.com/heppokofrontend/chrome-extension-close-duplicate-tabs#readme",
  "keywords": [],
  "license": "MIT",
  "packageManager": "npm@11.17.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heppokofrontend/chrome-extension-close-duplicate-tabs.git"
  },
  "scripts": {
    "build": "npm run type-check && node esbuild.config.mjs",
    "deploy": "gh-pages -d package -b package",
    "dev": "node esbuild.config.mjs --watch",
    "format-check": "prettier . --check",
    "format-fix": "prettier . --write",
    "lint-check": "eslint .",
    "lint-fix": "eslint . --fix",
    "predeploy": "npm run build",
    "serve": "http-server ./ -o index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  }
}
